# Copy to .env and fill in as needed. .env is git-ignored.
# Only required for the OPTIONAL LLM executive-summary step.

# --- Option A: local Ollama ---
# OLLAMA_HOST=http://localhost:11434
# LLM_MODEL=llama3.1

# --- Option B: hosted API (example: any OpenAI-compatible endpoint) ---
# LLM_API_BASE=https://api.example.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
